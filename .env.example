# AblePath local runtime
# Copy this file to .env and fill in real values as needed.
# Do not commit .env or real provider credentials.

# Server binding. Keep host on loopback for the local MVP.
ABLEPATH_HOST=127.0.0.1
ABLEPATH_PORT=4317

# Optional data directory. Defaults to ~/.config/ablepath.
# ABLEPATH_HOME=/home/you/.config/ablepath

# Background inactivity check interval in milliseconds.
# Set to 0 to disable the background checker.
ABLEPATH_INACTIVITY_CHECK_MS=60000

# Doubao OpenAI-compatible chat and vision provider.
ARK_API_KEY=
# Optional overrides. Defaults are suitable for the local MVP unless your Ark account uses custom endpoints.
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_CHAT_MODEL=doubao-seed-2-0-lite-260215
# DOUBAO_VISION_MODEL=doubao-seed-2-0-pro-260215

# Volc/Doubao ASR and realtime voice.
VOLC_ASR_APP_KEY=
VOLC_ASR_ACCESS_KEY=

# Optional ASR/realtime tuning.
VOLC_ASR_RESOURCE_ID=
STT_LANGUAGE=zh-CN
ASSISTANT_NAME=AblePath
DOUBAO_REALTIME_SPEAKER=
